{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ia-claude.local/schemas/kata-019/plan.schema.json",
  "title": "Plan",
  "description": "Structured, prioritized plan — never prose (FR-002, US3).",
  "type": "object",
  "additionalProperties": false,
  "required": ["plan_id", "directive_id", "steps", "revision_index", "created_at", "budget_exhausted"],
  "properties": {
    "plan_id": { "type": "string", "format": "uuid" },
    "directive_id": { "type": "string", "format": "uuid" },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["step_id", "priority", "description", "affects_modules"],
        "properties": {
          "step_id": { "type": "string" },
          "priority": { "type": "integer" },
          "description": { "type": "string", "minLength": 1 },
          "affects_modules": { "type": "array", "items": { "type": "string" } },
          "preconditions": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "revision_index": { "type": "integer", "minimum": 0 },
    "created_at": { "type": "string", "format": "date-time" },
    "budget_exhausted": { "type": "boolean" }
  }
}
