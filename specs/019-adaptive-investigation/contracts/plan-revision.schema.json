{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ia-claude.local/schemas/kata-019/plan-revision.schema.json",
  "title": "PlanRevision",
  "description": "Triggered re-planning record (FR-003, SC-004). Trigger is a closed enum — no 'other'.",
  "type": "object",
  "additionalProperties": false,
  "required": ["revision_id", "plan_id", "trigger", "diff_summary", "timestamp"],
  "properties": {
    "revision_id": { "type": "string", "format": "uuid" },
    "plan_id": { "type": "string", "format": "uuid" },
    "trigger": {
      "type": "string",
      "enum": ["precondition_failed", "new_dependency_discovered", "cycle_detected", "surprise_constraint"]
    },
    "diff_summary": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "format": "date-time" }
  }
}
