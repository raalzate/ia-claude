{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ia-claude.local/schemas/kata-001/event-log-record.schema.json",
  "title": "EventRecord",
  "description": "One JSONL line emitted per loop iteration. Sufficient on its own to reconstruct the loop's branch sequence and termination cause (FR-009, SC-007, SC-008). Constitution Principle VII (Provenance & Self-Audit).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "session_id",
    "iteration",
    "timestamp",
    "stop_signal",
    "branch_taken"
  ],
  "properties": {
    "session_id": {
      "type": "string",
      "description": "UUID4 of the parent AgentSession."
    },
    "iteration": {
      "type": "integer",
      "minimum": 0,
      "description": "Zero-indexed loop iteration this record describes."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "UTC ISO-8601 timestamp when the record was emitted."
    },
    "stop_signal": {
      "type": "string",
      "description": "String form of the structured stop signal. Recognized values are enumerated, but 'unhandled_signal' / 'absent_signal' are permitted surfaces for unrecognized or missing values.",
      "enum": [
        "tool_use",
        "end_turn",
        "max_tokens",
        "stop_sequence",
        "unhandled_signal",
        "absent_signal"
      ]
    },
    "branch_taken": {
      "type": "string",
      "enum": ["tool_dispatch", "terminate", "halt_unhandled"],
      "description": "What the loop did after observing the stop_signal."
    },
    "tool_name": {
      "type": ["string", "null"],
      "description": "Populated iff branch_taken == 'tool_dispatch'."
    },
    "tool_outcome": {
      "type": ["string", "null"],
      "enum": ["ok", "error", null],
      "description": "Populated iff branch_taken == 'tool_dispatch'."
    },
    "termination_cause": {
      "type": ["string", "null"],
      "enum": [
        "end_turn",
        "unhandled_signal",
        "absent_signal",
        "max_tokens",
        "stop_sequence",
        "malformed_tool_use",
        "tool_error_unrecoverable",
        null
      ],
      "description": "Populated only on the terminal iteration."
    }
  },
  "allOf": [
    {
      "description": "If branch_taken is tool_dispatch, tool_name and tool_outcome must be set.",
      "if": { "properties": { "branch_taken": { "const": "tool_dispatch" } } },
      "then": {
        "required": ["tool_name", "tool_outcome"],
        "properties": {
          "tool_name": { "type": "string" },
          "tool_outcome": { "enum": ["ok", "error"] }
        }
      }
    },
    {
      "description": "If branch_taken is terminate or halt_unhandled, termination_cause must be set.",
      "if": {
        "properties": { "branch_taken": { "enum": ["terminate", "halt_unhandled"] } }
      },
      "then": {
        "required": ["termination_cause"],
        "properties": {
          "termination_cause": {
            "type": "string",
            "enum": [
              "end_turn",
              "unhandled_signal",
              "absent_signal",
              "max_tokens",
              "stop_sequence",
              "malformed_tool_use",
              "tool_error_unrecoverable"
            ]
          }
        }
      }
    }
  ]
}
