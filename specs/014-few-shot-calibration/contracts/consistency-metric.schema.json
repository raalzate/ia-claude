{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ia-claude.local/schemas/kata-014/consistency-metric.schema.json",
  "title": "ConsistencyMetric",
  "description": "Per-trial record feeding a CalibrationReport (FR-004, SC-004).",
  "type": "object",
  "additionalProperties": false,
  "required": ["trial_id", "mode", "input_text", "schema_valid"],
  "properties": {
    "trial_id": { "type": "string" },
    "mode": { "type": "string", "enum": ["zero_shot", "few_shot"] },
    "set_id": { "type": ["string", "null"] },
    "input_text": { "type": "string" },
    "model_output": { "type": ["object", "null"] },
    "schema_valid": { "type": "boolean" },
    "matches_expected": { "type": ["boolean", "null"] }
  }
}
