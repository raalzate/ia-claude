{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ia-claude.local/schemas/kata-014/calibration-report.schema.json",
  "title": "CalibrationReport",
  "description": "Aggregated measurement over a corpus (SC-001).",
  "type": "object",
  "additionalProperties": false,
  "required": ["task_id", "corpus_size", "inconsistency_rate", "schema_violation_rate", "timestamp"],
  "properties": {
    "task_id": { "type": "string" },
    "set_id": { "type": ["string", "null"] },
    "corpus_size": { "type": "integer", "minimum": 1 },
    "inconsistency_rate": { "type": "number", "minimum": 0, "maximum": 1 },
    "schema_violation_rate": { "type": "number", "minimum": 0, "maximum": 1 },
    "zero_shot_baseline_rate": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 1,
      "description": "Paired zero-shot control measurement, when available."
    },
    "timestamp": { "type": "string", "format": "date-time" }
  }
}
