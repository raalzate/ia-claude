{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ia-claude.local/schemas/kata-014/example-set.schema.json",
  "title": "ExampleSet",
  "description": "Ordered 2-4 pairs. Contradictions across pairs are rejected (FR-005).",
  "type": "object",
  "additionalProperties": false,
  "required": ["set_id", "description", "pairs"],
  "properties": {
    "set_id": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "pairs": {
      "type": "array",
      "minItems": 2,
      "maxItems": 4,
      "items": { "$ref": "example-pair.schema.json" }
    }
  }
}
