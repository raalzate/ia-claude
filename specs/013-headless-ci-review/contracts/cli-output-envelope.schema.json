{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ia-claude.local/schemas/kata-013/cli-output-envelope.schema.json",
  "title": "CLIOutputEnvelope",
  "description": "The top-level JSON the Claude Code CLI emits under --output-format json --json-schema (FR-001, FR-002, SC-001). This schema is what the CLI itself is pinned to.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "findings", "summary"],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^\\d+\\.\\d+$" },
    "findings": {
      "type": "array",
      "items": { "$ref": "review-finding.schema.json" }
    },
    "summary": { "type": "string" },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "run_id": { "type": "string" },
        "model_id": { "type": "string" },
        "prompt_hash": { "type": "string" }
      }
    }
  }
}
