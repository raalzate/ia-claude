{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ia-claude.local/schemas/kata-012/stage-definition.schema.json",
  "title": "StageDefinition",
  "description": "Declarative stage metadata (FR-002, FR-003). Each stage has a bounded responsibility and a declared max_prompt_tokens budget.",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "responsibility", "input_schema_id", "output_schema_id", "max_prompt_tokens"],
  "properties": {
    "name": { "type": "string", "pattern": "^[a-zA-Z][\\w-]{0,63}$" },
    "responsibility": { "type": "string", "minLength": 1 },
    "input_schema_id": { "type": "string", "format": "uri" },
    "output_schema_id": { "type": "string", "format": "uri" },
    "max_prompt_tokens": { "type": "integer", "minimum": 1 },
    "order": { "type": "integer", "minimum": 0 }
  }
}
