{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ia-claude.local/schemas/kata-015/invoice-extraction.schema.json",
  "title": "InvoiceExtraction",
  "description": "Stated + derived-calculated totals, with conflict_detected computed (NEVER trusted from model). FR-001..FR-004.",
  "type": "object",
  "additionalProperties": false,
  "required": ["invoice_id", "currency", "stated_total", "calculated_total", "line_items", "conflict_detected"],
  "properties": {
    "invoice_id": { "type": "string", "minLength": 1 },
    "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
    "stated_total": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
    "calculated_total": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
    "line_items": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "line-item.schema.json" }
    },
    "tolerance_cents": { "type": "integer", "minimum": 0, "default": 1 },
    "conflict_detected": { "type": "boolean" }
  }
}
