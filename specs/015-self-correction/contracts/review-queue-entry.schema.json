{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ia-claude.local/schemas/kata-015/review-queue-entry.schema.json",
  "title": "ReviewQueueEntry",
  "description": "Handoff to a human reviewer (SC-004). 100% of ConflictRecords MUST produce one of these.",
  "type": "object",
  "additionalProperties": false,
  "required": ["entry_id", "conflict_record_id", "priority", "status"],
  "properties": {
    "entry_id": { "type": "string", "format": "uuid" },
    "conflict_record_id": { "type": "string", "format": "uuid" },
    "priority": { "type": "string", "enum": ["low", "medium", "high"] },
    "status": { "type": "string", "enum": ["pending", "in_review", "resolved"] },
    "resolution_note": { "type": ["string", "null"] }
  }
}
