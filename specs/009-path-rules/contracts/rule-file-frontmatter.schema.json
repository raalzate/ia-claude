{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ia-claude.local/schemas/kata-009/rule-file-frontmatter.schema.json",
  "title": "RuleFileFrontmatter",
  "description": "YAML frontmatter parsed from a `.claude/rules/*.md` file (FR-001, FR-003). Invalid frontmatter → FrontmatterError at load time.",
  "type": "object",
  "additionalProperties": false,
  "required": ["paths"],
  "properties": {
    "paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "Glob pattern, e.g. '**/*.test.tsx'."
      }
    },
    "precedence": {
      "type": "integer",
      "description": "Lower wins on overlap. Default 100 when absent.",
      "default": 100
    },
    "description": { "type": "string" }
  }
}
