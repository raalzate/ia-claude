{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ia-claude.local/schemas/kata-009/rule-activation-event.schema.json",
  "title": "RuleActivationEvent",
  "description": "Audit record per turn — which rule files activated for which edited file (FR-005, SC-004).",
  "type": "object",
  "additionalProperties": false,
  "required": ["turn_id", "edited_path", "activated_rules", "timestamp"],
  "properties": {
    "turn_id": { "type": "string" },
    "edited_path": { "type": "string" },
    "activated_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["rule_file", "matched_pattern", "precedence"],
        "properties": {
          "rule_file": { "type": "string" },
          "matched_pattern": { "type": "string" },
          "precedence": { "type": "integer" }
        }
      }
    },
    "token_cost_added": {
      "type": "integer",
      "minimum": 0,
      "description": "Extra tokens this activation contributed to the turn prompt (SC-001 proxy)."
    },
    "timestamp": { "type": "string", "format": "date-time" }
  }
}
