{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ia-claude.local/schemas/kata-016/escalation-event.schema.json",
  "title": "EscalationEvent",
  "description": "Audit-log record emitted whenever a HandoffPayload is dispatched (FR-009).",
  "type": "object",
  "additionalProperties": false,
  "required": ["event_id", "escalation_id", "handoff_payload_hash", "timestamp"],
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "escalation_id": { "type": "string", "format": "uuid" },
    "source_kata": { "type": ["string", "null"] },
    "handoff_payload_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "sha256 of the serialized HandoffPayload for tamper detection."
    },
    "timestamp": { "type": "string", "format": "date-time" }
  }
}
