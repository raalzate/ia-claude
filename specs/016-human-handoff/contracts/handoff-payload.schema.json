{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ia-claude.local/schemas/kata-016/handoff-payload.schema.json",
  "title": "HandoffPayload",
  "description": "The escalate_to_human tool's input schema. v1.1 — severity required. FR-001..FR-010.",
  "type": "object",
  "additionalProperties": false,
  "required": ["escalation_id", "customer_id", "issue_summary", "actions_taken", "escalation_reason", "severity", "created_at"],
  "properties": {
    "escalation_id": { "type": "string", "format": "uuid" },
    "customer_id": { "type": "string", "minLength": 1 },
    "issue_summary": { "type": "string", "minLength": 1, "maxLength": 500 },
    "actions_taken": {
      "type": "array",
      "items": { "$ref": "action-record.schema.json" }
    },
    "escalation_reason": {
      "type": "string",
      "enum": ["policy-breach", "out-of-policy-demand", "operational-limit", "unresolved-after-retries", "explicit-user-request"]
    },
    "severity": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
