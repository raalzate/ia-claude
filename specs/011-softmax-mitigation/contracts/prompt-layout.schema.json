{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ia-claude.local/schemas/kata-011/prompt-layout.schema.json",
  "title": "PromptLayout",
  "description": "One of three comparison layouts for A/B/C compliance testing (US1/US2/US3).",
  "type": "object",
  "additionalProperties": false,
  "required": ["strategy", "prefix_region", "body_region", "suffix_region"],
  "properties": {
    "strategy": {
      "type": "string",
      "enum": ["edge_placed", "mid_buried", "edge_placed_with_compaction"]
    },
    "prefix_region": {
      "type": "object",
      "required": ["rules", "token_budget"],
      "properties": {
        "rules": { "type": "array", "items": { "type": "string" } },
        "token_budget": { "type": "integer", "minimum": 0 }
      }
    },
    "body_region": {
      "type": "object",
      "required": ["content", "token_count"],
      "properties": {
        "content": { "type": "string" },
        "token_count": { "type": "integer", "minimum": 0 }
      }
    },
    "suffix_region": {
      "type": "object",
      "required": ["rules", "token_budget"],
      "properties": {
        "rules": { "type": "array", "items": { "type": "string" } },
        "token_budget": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
