{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ia-claude.local/schemas/kata-017/workload-profile.schema.json",
  "title": "WorkloadProfile",
  "description": "Input to WorkloadClassifier (FR-001).",
  "type": "object",
  "additionalProperties": false,
  "required": ["is_blocking", "latency_budget_seconds", "item_count", "expected_cost_usd"],
  "properties": {
    "is_blocking": { "type": "boolean" },
    "latency_budget_seconds": { "type": "integer", "minimum": 0 },
    "item_count": { "type": "integer", "minimum": 1 },
    "expected_cost_usd": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" }
  }
}
