{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ia-claude.local/schemas/kata-017/batch-job.schema.json",
  "title": "BatchJob",
  "description": "Pre- and post-submit shape; pydantic root-validator enforces custom_id uniqueness across items.",
  "type": "object",
  "additionalProperties": false,
  "required": ["items"],
  "properties": {
    "job_id": { "type": ["string", "null"] },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "batch-item.schema.json" }
    },
    "submitted_at": { "type": ["string", "null"], "format": "date-time" },
    "processing_status": {
      "type": ["string", "null"],
      "enum": ["draft", "in_progress", "ended", "canceled", null]
    }
  }
}
