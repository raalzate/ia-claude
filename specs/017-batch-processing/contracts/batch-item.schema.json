{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ia-claude.local/schemas/kata-017/batch-item.schema.json",
  "title": "BatchedItem",
  "description": "One item inside a BatchJob. custom_id is the correlation anchor (FR-003).",
  "type": "object",
  "additionalProperties": false,
  "required": ["custom_id", "request"],
  "properties": {
    "custom_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9_\\-\\.]+$"
    },
    "request": { "type": "object" }
  }
}
