{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ia-claude.local/schemas/kata-017/failure-bucket.schema.json",
  "title": "FailureBucket",
  "description": "Isolated failed items awaiting fragmentation + resubmission (FR-004, SC-004).",
  "type": "object",
  "additionalProperties": false,
  "required": ["round", "items", "parent_job_id"],
  "properties": {
    "round": { "type": "integer", "minimum": 1 },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "batch-item.schema.json" }
    },
    "parent_job_id": { "type": "string", "minLength": 1 },
    "max_rounds": { "type": "integer", "minimum": 1, "default": 4 },
    "permanently_failed": { "type": "array", "items": { "type": "string" } }
  }
}
