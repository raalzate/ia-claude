{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ia-claude.local/schemas/kata-006/mcp-tool-call.schema.json",
  "title": "ToolCall",
  "description": "One invocation of an MCP-exposed tool. Owns its own retry budget (FR-005). Retries construct a new ToolCall with parent_call_id set.",
  "type": "object",
  "additionalProperties": false,
  "required": ["call_id", "tool_name", "input", "attempt", "budget"],
  "properties": {
    "call_id": { "type": "string", "format": "uuid" },
    "tool_name": { "type": "string", "pattern": "^[a-zA-Z][\\w-]{0,63}$" },
    "input": { "type": "object" },
    "attempt": { "type": "integer", "minimum": 1 },
    "budget": { "$ref": "retry-budget.schema.json" },
    "parent_call_id": { "type": ["string", "null"], "format": "uuid" }
  }
}
