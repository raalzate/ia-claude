{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ia-claude.local/schemas/kata-018/context-anchor.schema.json",
  "title": "ContextAnchor",
  "description": "Post-compaction seed built from the scratchpad so the agent resumes without rediscovery (FR-003, SC-001).",
  "type": "object",
  "additionalProperties": false,
  "required": ["anchor_id", "generated_at", "decisions_snapshot", "open_questions_snapshot", "map_summary", "source_pad_id"],
  "properties": {
    "anchor_id": { "type": "string", "format": "uuid" },
    "generated_at": { "type": "string", "format": "date-time" },
    "decisions_snapshot": {
      "type": "array",
      "items": { "$ref": "finding.schema.json" }
    },
    "open_questions_snapshot": {
      "type": "array",
      "items": { "$ref": "finding.schema.json" }
    },
    "map_summary": { "type": "string", "maxLength": 400 },
    "source_pad_id": { "type": "string", "format": "uuid" }
  }
}
