{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ia-claude.local/schemas/kata-007/session-mode-transition.schema.json",
  "title": "SessionModeTransition",
  "description": "Append-only event recording a SessionMode transition. Every Plan-to-Execute transition carries the approved plan's identifier and hash (FR-005, SC-002).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "session_id",
    "from_mode",
    "to_mode",
    "at",
    "reason"
  ],
  "properties": {
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "from_mode": {
      "type": "string",
      "enum": ["plan", "execute"]
    },
    "to_mode": {
      "type": "string",
      "enum": ["plan", "execute"]
    },
    "at": {
      "type": "string",
      "format": "date-time"
    },
    "plan_task_id": {
      "type": ["string", "null"],
      "description": "Populated on plan<->execute crossings that reference a specific plan."
    },
    "plan_hash": {
      "type": ["string", "null"],
      "pattern": "^([0-9a-f]{64})?$",
      "description": "Populated on plan->execute. Matches the HumanApprovalEvent.plan_hash that authorized the transition."
    },
    "approved_by": {
      "type": ["string", "null"],
      "description": "Populated on plan->execute transitions (FR-005)."
    },
    "reason": {
      "type": "string",
      "enum": [
        "approval_verified",
        "plan_hash_mismatch",
        "scope_change_detected",
        "approval_revoked",
        "session_start",
        "small_refactor_bypass",
        "infeasible_plan",
        "execution_interrupted"
      ],
      "description": "Closed enumeration of transition reasons. No 'other' escape — the state machine is total."
    }
  }
}
