{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ia-claude.local/schemas/kata-010/cache-metric-record.schema.json",
  "title": "CacheMetricRecord",
  "description": "Per-request metric from response.usage (FR-004). Offline fixture mode replays recorded usage blocks.",
  "type": "object",
  "additionalProperties": false,
  "required": ["request_id", "input_tokens", "cache_read_input_tokens", "cache_creation_input_tokens", "timestamp"],
  "properties": {
    "request_id": { "type": "string" },
    "input_tokens": { "type": "integer", "minimum": 0 },
    "cache_read_input_tokens": { "type": "integer", "minimum": 0 },
    "cache_creation_input_tokens": { "type": "integer", "minimum": 0 },
    "output_tokens": { "type": "integer", "minimum": 0 },
    "cache_hit_rate": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "cache_read / (cache_read + cache_creation + input)."
    },
    "timestamp": { "type": "string", "format": "date-time" }
  }
}
