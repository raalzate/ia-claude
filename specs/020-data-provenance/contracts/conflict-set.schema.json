{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ia-claude.local/schemas/kata-020/conflict-set.schema.json",
  "title": "ConflictSet",
  "description": "Two or more claims sharing a canonical key but disagreeing on content (FR-003, SC-002). Never auto-resolved.",
  "type": "object",
  "additionalProperties": false,
  "required": ["canonical_key", "conflict_detected", "claims"],
  "properties": {
    "canonical_key": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "conflict_detected": { "const": true },
    "claims": {
      "type": "array",
      "minItems": 2,
      "items": { "$ref": "claim.schema.json" }
    },
    "numeric_divergence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    }
  }
}
