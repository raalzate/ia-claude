{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ia-claude.local/schemas/kata-020/claim.schema.json",
  "title": "Claim",
  "description": "Fact unit with schema-required provenance (FR-001, SC-001, SC-004).",
  "type": "object",
  "additionalProperties": false,
  "required": ["claim_id", "claim", "source_name", "canonical_key", "extracted_by"],
  "properties": {
    "claim_id": { "type": "string", "format": "uuid" },
    "claim": { "type": "string", "minLength": 1 },
    "source_name": { "type": "string", "minLength": 1 },
    "source_url": {
      "type": ["string", "null"],
      "description": "https://…, file://…, or internal://source-id. Null permitted for truly internal sources; source_name must still be set."
    },
    "publication_date": {
      "type": ["string", "null"],
      "format": "date"
    },
    "canonical_key": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "extracted_by": { "type": "string", "minLength": 1 }
  }
}
