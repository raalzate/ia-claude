{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ia-claude.local/schemas/kata-020/subagent-claims-payload.schema.json",
  "title": "SubagentClaimsPayload",
  "description": "Handoff contract from each subagent to the coordinator (Principle IV; FR-005).",
  "type": "object",
  "additionalProperties": false,
  "required": ["subagent_id", "source_ids", "claims"],
  "properties": {
    "subagent_id": { "type": "string", "minLength": 1 },
    "source_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "claims": {
      "type": "array",
      "items": { "$ref": "claim.schema.json" }
    },
    "notes": { "type": ["string", "null"] }
  }
}
