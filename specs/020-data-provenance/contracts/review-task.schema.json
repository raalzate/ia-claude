{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ia-claude.local/schemas/kata-020/review-task.schema.json",
  "title": "ReviewTask",
  "description": "Human escalation for conflict resolution (FR-004).",
  "type": "object",
  "additionalProperties": false,
  "required": ["task_id", "conflict_set_key", "status"],
  "properties": {
    "task_id": { "type": "string", "format": "uuid" },
    "conflict_set_key": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "status": { "type": "string", "enum": ["pending", "resolved"] },
    "resolution_note": { "type": ["string", "null"] }
  }
}
